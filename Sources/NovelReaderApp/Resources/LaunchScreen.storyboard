<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.Storyboard.XIB" version="3.0" toolsVersion="23504" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" launchScreen="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES" initialViewController="launch-view-controller">
    <device id="retina6_12" orientation="portrait" appearance="light"/>
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="23506"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="System colors in document resources" minToolsVersion="11.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <scenes>
        <scene sceneID="launch-scene">
            <objects>
                <viewController id="launch-view-controller" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="launch-view">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <subviews>

                            <!-- Icon badge: dark rounded square -->
                            <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="icon-badge">
                                <rect key="frame" x="156.5" y="346" width="80" height="80"/>
                                <subviews>
                                    <!-- "阅" character -->
                                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="元" textAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="icon-label">
                                        <rect key="frame" x="0.0" y="0.0" width="80" height="80"/>
                                        <fontDescription type="system" pointSize="38"/>
                                        <color key="textColor" red="0.909803921" green="0.862745098" blue="0.784313725" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                        <constraints>
                                            <constraint firstAttribute="width" constant="80" id="icon-label-width"/>
                                            <constraint firstAttribute="height" constant="80" id="icon-label-height"/>
                                        </constraints>
                                        <nil key="highlightedColor"/>
                                    </label>
                                </subviews>
                                <color key="backgroundColor" red="0.172549019" green="0.227450980" blue="0.290196078" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                <constraints>
                                    <constraint firstAttribute="width" constant="80" id="badge-width"/>
                                    <constraint firstAttribute="height" constant="80" id="badge-height"/>
                                </constraints>
                            </view>

                            <!-- App name: "元阅" -->
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="元阅" textAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="app-name-label">
                                <rect key="frame" x="96.5" y="446" width="200" height="18"/>
                                <fontDescription type="system" pointSize="11"/>
                                <color key="textColor" red="0.305882352" green="0.392156862" blue="0.501960784" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                <constraints>
                                    <constraint firstAttribute="width" constant="200" id="name-label-width"/>
                                </constraints>
                                <nil key="highlightedColor"/>
                            </label>

                            <!-- Sub-tagline: "MetaRead" -->
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="MetaRead" textAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="sub-label">
                                <rect key="frame" x="156.5" y="468" width="80" height="16"/>
                                <fontDescription type="system" pointSize="10"/>
                                <color key="textColor" red="0.469" green="0.439" blue="0.392" alpha="0.55" colorSpace="custom" customColorSpace="sRGB"/>
                                <constraints>
                                    <constraint firstAttribute="width" constant="80" id="sub-label-width"/>
                                </constraints>
                                <nil key="highlightedColor"/>
                            </label>

                        </subviews>
                        <viewLayoutGuide key="safeArea" id="launch-safe-area"/>
                        <!-- Background: warm parchment #EDEAE3 -->
                        <color key="backgroundColor" red="0.929411764" green="0.917647058" blue="0.890196078" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                        <constraints>
                            <!-- Icon badge: centered horizontally, centered vertically −40pt -->
                            <constraint firstItem="icon-badge" firstAttribute="centerX" secondItem="launch-view" secondAttribute="centerX" id="badge-cx"/>
                            <constraint firstItem="icon-badge" firstAttribute="centerY" secondItem="launch-view" secondAttribute="centerY" constant="-40" id="badge-cy"/>
                            <!-- App name: centered horizontally, 18pt below badge -->
                            <constraint firstItem="app-name-label" firstAttribute="centerX" secondItem="launch-view" secondAttribute="centerX" id="name-cx"/>
                            <constraint firstItem="app-name-label" firstAttribute="top" secondItem="icon-badge" secondAttribute="bottom" constant="18" id="name-top"/>
                            <!-- Sub-tagline: centered horizontally, 4pt below app name -->
                            <constraint firstItem="sub-label" firstAttribute="centerX" secondItem="launch-view" secondAttribute="centerX" id="sub-cx"/>
                            <constraint firstItem="sub-label" firstAttribute="top" secondItem="app-name-label" secondAttribute="bottom" constant="4" id="sub-top"/>
                        </constraints>
                    </view>
                </viewController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="first-responder" userLabel="First Responder" sceneMemberID="firstResponder"/>
            </objects>
            <point key="canvasLocation" x="0.0" y="0.0"/>
        </scene>
    </scenes>
</document>
